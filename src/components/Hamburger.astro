<button
  class="ly_aside_btn bl_hamburger js_hamburger"
  data-mouse="stuck"
  aria-label="メニューを開く"
>
  <span class="bl_hamburger_inner">
    <span class="bl_hamburger_wrap js_hamburger_wrap">
      <span class="bl_hamburger_bar js_hamburger_bar"></span>
    </span>
    <span class="bl_hamburger_wrap js_hamburger_wrap">
      <span class="bl_hamburger_bar js_hamburger_bar"></span>
    </span>
    <span class="bl_hamburger_wrap js_hamburger_wrap">
      <span class="bl_hamburger_bar js_hamburger_bar"></span>
    </span>
  </span>
</button>

<style lang="scss">
  .bl_hamburger {
    position: relative;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 5em;
    height: 5em;
    border: 0;
    background: none;
    margin-bottom: 10px;
    cursor: pointer;
    pointer-events: auto;
    &_inner {
      position: relative;
      display: block;
      width: 2em;
      height: 1px;
    }
    &_wrap {
      position: absolute;
      left: 0;
      width: 100%;
      &:first-child {
        transform: translateY(-0.5em);
      }
      &:last-child {
        transform: translateY(0.5em);
      }
    }
    &_bar {
      display: block;
      width: 100%;
      height: 1px;
      background-color: white;
    }
  }
</style>
