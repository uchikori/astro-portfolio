<div class="bl_menu">
  <div class="bl_menu_inner">
    <nav class="bl_menu_nav">
      <ul class="bl_menu_ul">
        <li class="bl_menu_li">
          <a href="/" class="bl_menu_link">HOME</a>
        </li>
        <li class="bl_menu_li">
          <a href="/" class="bl_menu_link">VISION</a>
