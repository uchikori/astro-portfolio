<style lang="scss">
  .bl_menu {
    position: fixed;
    z-index: 100;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: white;
    overflow: hidden;
    display: flex;
    align-items: center;
    pointer-events: none;

    clip-path: circle(0px at calc(100% - 2.5em) 2.5em);
    transition:
      clip-path 0.4s ease 0.4s,
      pointer-events 0s 0.8s;

    &_inner {
      font-size: 32px;
      font-weight: 700;
      width: 100%;
      max-width: 90%;
      margin-inline: auto;
      display: flex;
      justify-content: space-between;
    }

    &_nav {
      width: 100%;
    }

    &_ul {
      display: flex;
      flex-direction: column;
      gap: 0.5em;
    }

    &_li {
      list-style: none;
      opacity: 0;
      transform: scaleY(0);
      transform-origin: bottom;
      transition:
        transform 0.2s,
        opacity 0.2s;
    }

    & a {
      width: 100%;
      display: grid;
      // デフォルト（PC）は2列。7emで固定することで英語ラベルの頭が揃います。
      grid-template-columns: repeat(auto-fit, minmax(7em, 1fr));
      color: black;
      text-decoration: none;
      transition: transform 0.4s ease;

      & > span:first-child {
        display: block;
        position: relative;

        @media (hover: hover) {
          overflow: hidden;
          white-space: nowrap;

          &::after {
            content: attr(data-text) "\a0\a0\a0" attr(data-text) "\a0\a0\a0"
              attr(data-text) "\a0\a0\a0" attr(data-text) "\a0\a0\a0";
            position: absolute;
            left: 0;
            top: 0;
            width: max-content;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
          }
        }
      }

      @media (hover: hover) {
        &:hover > span:first-child {
          color: transparent;

          &::after {
            opacity: 1;
            color: black;
            animation: marquee 3s linear infinite;
          }
        }
      }

      & > span:nth-child(2) {
        font-size: 0.5em;
        display: flex;
        align-items: center;
        flex: 1 1 auto;
        gap: 12px;

        &:before {
          content: "";
          width: 1em;
          height: 1px;
          background-color: currentColor;
          display: inline-block;
          opacity: 0.6;
        }
      }
    }

    &_li:hover a {
      color: #868686;
      transform: translateX(5%);
    }

    :global(.js_menu_open) & {
      pointer-events: auto;
      clip-path: circle(140% at calc(100% - 2.5em) 2.5em);
      transition: clip-path 0.4s cubic-bezier(1, 0, 1, 0) 0.1s;

      &_li {
        opacity: 1;
        transform: scaleY(1);
        @for $i from 1 through 7 {
          &:nth-child(#{$i}) {
            transition-delay: calc(0.6s + 0.07s * $i);
          }
        }
      }
    }
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-25%);
    }
  }
</style>
