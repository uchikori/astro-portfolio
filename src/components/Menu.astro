<style lang="scss">
  .bl_menu {
    position: fixed;
    z-index: 10;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: white;
    overflow: hidden;
    display: flex;
    align-items: center;

    clip-path: circle(0px at calc(100% - 2.5em) 2.5em);
    transition: clip-path 0.4s ease 0.4s;

    &_inner {
      font-size: 96px;
      font-weight: 700;
      width: 100%;
      margin: 2em;
      display: flex;
      justify-content: space-between;
    }

    &_li {
      list-style: none;
      // opacity: 0;
      // transform: scaleY(0);
      transform-origin: bottom;
      transition:
        transform 0.2s,
        opacity 0.2s;
    }

    & a {
      display: block;
      color: black;
      text-decoration: none;
      transition: transform 0.4s ease;
    }

    &_li:hover a {
      color: #868686;
      transform: translateX(5%);
    }
  }

  .menu-open {
    .bl_menu {
      clip-path: circle(140% at calc(100% - 2.5em) 2.5em);
      transition: clip-path 1s cubic-bezier(1, 0, 1, 0) 0.1s;

      &_li {
        opacity: 1;
        transform: scaleY(1);
        @for $i from 1 through 5 {
          &:nth-child(#{$i}) {
            transition-delay: calc(0.6s + 0.1s * $i);
          }
        }
      }
    }
  }
</style>
