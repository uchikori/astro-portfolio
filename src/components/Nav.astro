---
//alignの初期値を'right'に設定
const { align = "right" } = Astro.props;
---

<div class:list={["bl_nav", { "is-left": align === "left" }]}>
  <button class="el_navBtn el_navBtn__prev js_navBtn__prev">
    <img src="/img/slide-nav.svg" alt="前へ" />
  </button>
  <button class="el_navBtn el_navBtn__next js_navBtn__next">
    <img src="/img/slide-nav.svg" alt="次へ" />
  </button>
</div>
<style lang="scss">
  .bl_nav {
    font-size: 120px;
    text-align: right;
    position: absolute;
    bottom: 10%;
    right: 0.3em;
    height: 1em;
    width: 100%;
    &.is-left {
      text-align: left;
    }
  }

  .el_navBtn {
    background-color: transparent;
    border: none;
    opacity: 0.7;
    cursor: pointer;
    padding: 0;

    &:active {
      transform: scale(0.85);
    }

    &__prev {
      img {
        transform: rotate(180deg);
      }
    }
  }
</style>
