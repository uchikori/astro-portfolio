---

<div id="loader" class="loader un_loadingOverlay">
  <div class="un_loadingOverlay_glowEffect"></div>
  <div class="loader_inner">
    <!-- Module: カウンター -->
    <div id="js_progressCounter" class="m_progressCounter">
      <span id="js_countNum" class="m_progressCounter_displayNumber">0</span>
      <span class="m_progressCounter_unitSymbol">%</span>
    </div>
    <!-- Module: ローダー (構造継承) -->
    <div id="js_loaderWrapper" class="m_loaderWrapper">
      <div class="m_loaderWrapper_innerTrack">
        <div id="js_progressBar" class="m_loaderWrapper_progressRect"></div>
      </div>
      <div id="js_statusLabel" class="m_loaderWrapper_statusMessage">
        System Loading
      </div>
    </div>
  </div>
</div>

<style lang="scss">
  .un_loadingOverlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    background: #110028;
    opacity: 1;
    visibility: visible;
    &_glowEffect {
      position: absolute;
      width: 500px;
      height: 500px;
      background: radial-gradient(
        circle,
        rgba(59, 130, 246, 0.12) 0%,
        transparent 70%
      );
      z-index: -1;
    }
  }
  /* カウンター表示 */
  .m_progressCounter {
    color: #ffffff;
    margin-bottom: 30px;
    text-align: center;
    transform: translateX(0);
    &_displayNumber {
      font-size: 6rem;
      font-weight: 900;
      letter-spacing: -2px;
      line-height: 1;
    }
    &__unitSymbol {
      font-size: 1.5rem;
      color: #475569;
      margin-left: 5px;
    }

    .hl_isHidden & {
      transform: translateX(100%);
      opacity: 0;
      transition:
        transform 0.3s ease,
        opacity 0.3s ease;
    }
  }

  /* ローダー構造 */
  .m_loaderWrapper {
    width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translateX(0);
    &_innerTrack {
      position: relative;
      width: 100%;
      height: 4px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 10px;
      overflow: hidden;
    }
    &_progressRect {
      position: absolute;
      top: 0;
      left: 0;
      width: 0%; /* JSで制御 */
      height: 100%;
      background: linear-gradient(90deg, #3b82f6, #60a5fa);
      box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
      transition: width 0.15s ease-out;
    }
    &_statusMessage {
      margin-top: 20px;
      font-size: 0.75rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.25em;
    }

    .hl_isHidden & {
      transform: translateX(-100%);
      opacity: 0;
      transition:
        transform 0.3s ease,
        opacity 0.3s ease;
    }
  }

  /* ==========================================================================
    Helper (h_xxx)
========================================================================== */
  .hl_isHidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .hl_isCompleted {
    color: #10b981 !important;
  }
</style>
