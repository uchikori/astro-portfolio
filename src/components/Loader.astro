---

---

<div id="loader" class="bl_loader js_loader">
  <div class="bl_loader_glow"></div>
  <div class="bl_loader_inner">
    <!-- Module: カウンター -->
    <div id="js_progressCounter" class="bl_progressCounter js_progressCounter">
      <span id="js_countNum" class="bl_progressCounter_num js_countNum">0</span>
      <span class="bl_progressCounter_unit">%</span>
    </div>
    <!-- /.bl_progressCounter -->

    <!-- Module: ローダー構造 -->
    <div id="js_loaderWrapper" class="bl_loaderBar js_loaderBar">
      <div class="bl_loaderBar_track">
        <div id="js_progressBar" class="bl_loaderBar_progress js_progressBar"></div>
      </div>
      <!-- /.bl_loaderBar_track -->
      <div id="js_statusLabel" class="bl_loaderBar_status js_statusLabel">
        System Loading
      </div>
    </div>
    <!-- /.bl_loaderBar -->
  </div>
  <!-- /.bl_loader_inner -->
</div>
<!-- /.bl_loader -->

<style lang="scss">
  .bl_loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    background: #110028;
    opacity: 1;
    visibility: visible;
    &_glow {
      position: absolute;
      width: 500px;
      height: 500px;
      background: radial-gradient(
        circle,
        rgba(59, 130, 246, 0.12) 0%,
        transparent 70%
      );
      z-index: -1;
    }
  }

  /* カウンター表示 */
  .bl_progressCounter {
    color: #ffffff;
    margin-bottom: 30px;
    text-align: center;
    transform: translateX(0);
    &_num {
      font-size: 6rem;
      font-weight: 900;
      letter-spacing: -2px;
      line-height: 1;
    }
    &_unit {
      font-size: 1.5rem;
      color: #475569;
      margin-left: 5px;
    }

    .is_hidden & {
      transform: translateX(100%);
      opacity: 0;
      transition:
        transform 0.3s ease,
        opacity 0.3s ease;
    }
  }

  /* ローダー構造 */
  .bl_loaderBar {
    width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translateX(0);
    &_track {
      position: relative;
      width: 100%;
      height: 4px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 10px;
      overflow: hidden;
    }
    &_progress {
      position: absolute;
      top: 0;
      left: 0;
      width: 0%; /* JSで制御 */
      height: 100%;
      background: linear-gradient(90deg, #3b82f6, #60a5fa);
      box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
      transition: width 0.15s ease-out;
    }
    &_status {
      margin-top: 20px;
      font-size: 0.75rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.25em;
    }

    .is_hidden & {
      transform: translateX(-100%);
      opacity: 0;
      transition:
        transform 0.3s ease,
        opacity 0.3s ease;
    }
  }

  /* ==========================================================================
    State (is_xxx)
  ========================================================================== */
  .is_hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .is_completed {
    color: #10b981 !important;
  }
</style>
