---
const { title = "Astro" } = Astro.props;
import "../styles/style.scss";
import Loader from "../components/Loader.astro";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <script type="module" src="/src/scripts/index.js"></script>
    <title>{title}</title>
    <link
      rel="preload"
      href="/fonts/Orbitron-Medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Orbitron-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <slot name="head" />
  </head>
  <body>
    <Loader />
    <div id="globalContainer">
      <slot />
      <canvas id="canvas"></canvas>
    </div>
  </body>
</html>

<style lang="scss">
  /* Orbitron Medium */
  @font-face {
    font-family: "Orbitron";
    src: url("/fonts/Orbitron-Medium.woff2") format("woff2");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
    unicode-range: U+0020-007F;
  }

  /* Orbitron Bold */
  @font-face {
    font-family: "Orbitron";
    src: url("/fonts/Orbitron-Bold.woff2") format("woff2");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
    unicode-range: U+0020-007F;
  }
  body {
    margin: 0;
    background-color: #434243;
    font-family:
      "Orbitron",
      "Noto Sans JP",
      system-ui,
      -apple-system,
      "Segoe UI",
      sans-serif;
  }

  #globalContainer {
    position: relative;
    overflow: clip;
    visibility: hidden;
    z-index: 0;
  }

  #canvas {
    height: 100vh;
    width: 100vw;
    position: fixed;
    top: 0;
    left: 0;
    z-index: -1;
  }
</style>
