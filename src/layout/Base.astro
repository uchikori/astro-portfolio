---
const { title = "Astro" } = Astro.props;
import "../styles/style.scss";
import Loader from "../components/Loader.astro";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <script type="module" src="/src/scripts/index.js"></script>
    <title>{title}</title>
    <link
      rel="preload"
      href="/fonts/Orbitron-Medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Orbitron-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <!-- Google Fonts の読み込みを追加 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <Loader />
    <div id="globalContainer">
      <div id="smooth-wrapper">
        <div id="smooth-content">
          <slot />
        </div>
      </div>
      <canvas id="canvas"></canvas>
      <!-- <svg
        class="el_mousePointer"
        width="400"
        height="400"
        preserveAspectRatio="xMidYMid meet"
        viewBox="0 0 200 400"
        style="background:white;"
      >
        <rect width="400" height="400" x="0" y="0" stroke="red" stroke-width="4"
        ></rect>
        <circle cx="100" cy="100" r="100" fill="red"></circle>
        <circle cx="200" cy="200" r="100" fill="purple"></circle>
      </svg> -->
    </div>
  </body>
</html>
